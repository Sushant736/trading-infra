cat > .gitignore << 'EOF'
# Environment
.env
.env.local
.env.*.local

# Dependencies
node_modules/
vendor/

# Build outputs
dist/
build/
*.exe
*.bin

# Go
*.test
coverage.out

# Logs
*.log
logs/

# Docker
.docker/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
EOF